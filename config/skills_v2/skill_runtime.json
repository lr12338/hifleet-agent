{
  "version": 1,
  "description": "Shared Skills V2 运行时配置。实际 skill_runtime 模式由 src/skills_v2/core/policy.py 从 config/agent_profiles.json 及环境变量解析；此文件记录 V2 默认值与 V2 专用设置。",
  "profiles": {
    "customer_ceshi": {
      "default_mode": "v2",
      "env_override": "CUSTOMER_CESHI_SKILLS_MODE",
      "allowed_modes": [
        "v2",
        "legacy"
      ],
      "fallback": "safe_constrained（不加载 legacy Skills）"
    },
    "customer_support": {
      "default_mode": "legacy",
      "env_override": "CUSTOMER_SUPPORT_SKILLS_MODE",
      "allowed_modes": [
        "legacy"
      ],
      "shadow_env_override": "CUSTOMER_SUPPORT_SKILLS_SHADOW",
      "shadow_default": false
    }
  },
  "v2_skills": [
    "knowledge_retrieval",
    "web_search",
    "hifleet_data",
    "ship_info_update"
  ],
  "v2_lock": "src/skills_v2/upstream/hifleet_skills/lock.json",
  "capability_map": "src/skills_v2/upstream/hifleet_skills/capability_map.yaml"
}
