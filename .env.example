# Hifleet智能客服环境变量配置模板
# 使用方法：复制此文件为.env，并填入真实值

# ==================== 大模型API配置 ====================
# Coze平台API密钥（必需）
# 获取方式：Coze控制台 -> API密钥管理
COZE_WORKLOAD_IDENTITY_API_KEY=your_api_key_here

# Coze平台API地址（必需，一般不需要修改）
COZE_INTEGRATION_MODEL_BASE_URL=https://api.coze.cn

# 使用火山 Ark 时，请改为：
# COZE_WORKLOAD_IDENTITY_API_KEY=your_ark_api_key_here
# COZE_INTEGRATION_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ==================== 船舶服务API配置 ====================
# 船舶服务工作流API地址（必需）
SHIP_SERVICE_API_URL=https://y3rz9srmmb.coze.site/run

# 船舶服务API Token（必需）
# 获取方式：Coze平台 -> API配置 -> 查看Authorization头
# 注意：只需要Bearer后面的部分，不要包含"Bearer "前缀
SHIP_SERVICE_API_TOKEN=your_token_here

# ==================== 数据库配置（可选） ====================
# Supabase数据库地址（用于线索收集）
# SUPABASE_URL=https://your-project.supabase.co

# Supabase数据库密钥
# SUPABASE_KEY=your_supabase_key

# 共享持久化会话记忆（Postgres checkpointer，推荐生产开启）
# 示例：postgresql://user:password@host:5432/dbname
# PGDATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres

# Checkpointer 模式：
# - postgres: 强制使用Postgres（无PGDATABASE_URL会启动失败）
# - auto: 优先Postgres，失败回退MemorySaver
# - memory: 仅使用进程内内存（不支持多worker会话一致性）
COZE_CHECKPOINTER_MODE=postgres

# HTTP worker 数量（共享checkpointer开启后建议 2~4）
COZE_HTTP_WORKERS=4

# ==================== 后台与OSS上传配置（可选） ====================
# 后台管理接口鉴权（配置后 /admin/* 需要请求头 x-admin-api-key）
# ADMIN_API_KEY=your_admin_api_key

# 后台测试代理默认目标地址（可选）
# AGENT_BASE_URL=http://127.0.0.1:10123

# 阿里云 OSS 上传（Chat Debug 附件上传必需）
# OSS_ACCESS_KEY_ID=your_oss_access_key_id
# OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
# OSS_BUCKET_NAME=hifleet-rag
# OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
# OSS_REGION=cn-beijing
# ADMIN_UPLOAD_MAX_MB=100

# ==================== 其他配置（可选） ====================
# Coze OAuth JWT Client ID（默认已内置，可按需覆盖）
# COZE_JWT_OAUTH_CLIENT_ID=1170095929405

# Coze OAuth JWT 密钥配置（二选一或混用）
# 方式1：单组密钥（推荐）
# COZE_JWT_KEY_NAME=hifleet_prod_key
# COZE_JWT_PUBLIC_KEY_ID=your_public_key_id
# COZE_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 方式2：多组密钥（可轮询），可配置 COZE_KEY_1_* ~ COZE_KEY_10_*
# COZE_KEY_1_NAME=hifleet_key_1
# COZE_KEY_1_PUBLIC_KEY_ID=your_public_key_id_1
# COZE_KEY_1_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# COZE_KEY_2_NAME=hifleet_key_2
# COZE_KEY_2_PUBLIC_KEY_ID=your_public_key_id_2
# COZE_KEY_2_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 方式3：JSON 配置（字符串或文件）
# COZE_KEY_CONFIGS_JSON=[{"name":"key1","public_key_id":"kid1","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"}]
# COZE_KEY_CONFIGS_FILE=/abs/path/to/coze_key_configs.json

# 备用静态 Token（JWT 刷新失败时回退）
# COZE_BACKUP_PAT_TOKEN=pat_xxx
# COZE_ACCESS_TOKEN=pat_xxx

# 知识库API密钥
# COZE_KNOWLEDGE_API_KEY=your_knowledge_api_key

# 火山方舟 Responses API（Chat Debug 使用）
# ARK_API_KEY=your_ark_api_key
# ARK_RESPONSES_URL=https://ark.cn-beijing.volces.com/api/v3/responses

# 日志级别
# LOG_LEVEL=INFO

# 超时时间（秒）
# API_TIMEOUT=30
